friendlist=["Chidi","Zachariah","Mason","Jayden","Johann"]
print(f'\nfriendlist = {friendlist}\n')

#total num. of items in a list
print(f'Toltal items = {len(friendlist)}\n')

#Adding an item into the list
friendlist.append('Joshua')
print(f'Updated friendlist = {len(friendlist)}\n')

#deleteing an item by its name
friendlist.remove('Mason')
print(f'\nfriendlist = {friendlist}\n')

#deleteing and item using its index
friendlist.pop(4)
print(f'\nfriendlist = {friendlist}\n')

#iterating list items
tot_item=len(friendlist)
print(f"Total items in friendlist={tot_item}\n")

for i in range(len(friendlist)):
    print(f"Name(or item) at index {i}={friendlist[i]}")
